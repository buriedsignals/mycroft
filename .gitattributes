# Enforce LF line endings for shell scripts and source files
*.sh       text eol=lf
*.command  text eol=lf
*.py       text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.css      text eol=lf
*.js       text eol=lf
*.svg      text eol=lf

# Binary-ish
*.png binary
*.jpg binary
*.ico binary
