#!/usr/bin/env python3
"""
mycroft-fetch — Provenance-capturing web fetch/search for the SIFT/C2PA demo

Sovereign default: scrape via Crawl4AI, search via SearXNG; Firecrawl is an
optional fallback. Captures content hashes and access metadata so SIFT
verification trails can be encoded as C2PA ingredients. acquisition_method
records the tool that actually acquired the evidence.

Usage:
    mycroft-fetch scrape <url> [--format markdown|html] [--output FILE]
    mycroft-fetch search <query> [--limit N]
    mycroft-fetch provenance list
    mycroft-fetch provenance show <id>

Environment:
    SEARXNG_URL          Local SearXNG endpoint (default http://localhost:8899)
    FIRECRAWL_API_KEY    Optional — enables the Firecrawl fallback
    MYCROFT_PROV_DIR     Provenance storage (default: ~/.mycroft/provenance)
"""

import argparse
import hashlib
import json
import os
import shutil
import subprocess
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

# Mirrors the sovereign provider helpers in scripts/mycroft-fetch (leaner demo
# schema here) — keep the two in sync manually.
FETCH_TIMEOUT = 90  # seconds; bound the headless-browser fetch so a hung crwl can't stall


# --- Configuration ---

PROV_DIR = Path(os.environ.get('MYCROFT_PROV_DIR', Path.home() / '.mycroft' / 'provenance'))


# --- Provenance Record ---

def create_provenance_record(url: str, content: str, format: str, command: str,
                             acquisition_method: str = 'crawl4ai') -> dict:
    """Create a provenance record for fetched content."""
    content_bytes = content.encode('utf-8')

    return {
        'id': f"prov-{uuid.uuid4().hex[:12]}",
        'url': url,
        'access_timestamp': datetime.now(timezone.utc).isoformat(),
        'content_hash': f"sha256:{hashlib.sha256(content_bytes).hexdigest()}",
        'content_length': len(content_bytes),
        'format': format,
        'command': command,
        'acquisition_method': acquisition_method,
        'scraper_version': get_scraper_version(acquisition_method),
    }


def save_provenance(record: dict, content: str) -> Path:
    """Save provenance record and content to disk."""
    PROV_DIR.mkdir(parents=True, exist_ok=True)

    prov_id = record['id']

    # Save provenance metadata
    meta_path = PROV_DIR / f"{prov_id}.json"
    with open(meta_path, 'w') as f:
        json.dump(record, f, indent=2)

    # Save content
    ext = 'md' if record['format'] == 'markdown' else 'html'
    content_path = PROV_DIR / f"{prov_id}.{ext}"
    with open(content_path, 'w') as f:
        f.write(content)

    return meta_path


def list_provenance() -> list:
    """List all provenance records."""
    if not PROV_DIR.exists():
        return []

    records = []
    for path in PROV_DIR.glob('prov-*.json'):
        with open(path) as f:
            records.append(json.load(f))

    return sorted(records, key=lambda r: r['access_timestamp'], reverse=True)


def get_provenance(prov_id: str) -> dict | None:
    """Get a specific provenance record."""
    path = PROV_DIR / f"{prov_id}.json"
    if path.exists():
        with open(path) as f:
            return json.load(f)
    return None


# --- Firecrawl Integration ---

def get_firecrawl_version() -> str:
    """Get firecrawl CLI version."""
    try:
        result = subprocess.run(
            ['firecrawl', '--version'],
            capture_output=True,
            text=True
        )
        return result.stdout.strip() or 'unknown'
    except FileNotFoundError:
        return 'not-installed'


def get_scraper_version(method: str) -> str:
    """Version of the tool that actually acquired the evidence."""
    if method == 'crawl4ai':
        try:
            r = subprocess.run(['uv', 'tool', 'list'], capture_output=True, text=True)
            for line in r.stdout.splitlines():
                if line.strip().startswith('crawl4ai'):
                    parts = line.split()
                    return 'crawl4ai ' + parts[1] if len(parts) > 1 else 'crawl4ai'
        except FileNotFoundError:
            pass
        return 'crawl4ai'
    if method == 'firecrawl':
        return get_firecrawl_version()
    if method == 'searxng':
        return 'searxng@' + os.environ.get('SEARXNG_URL', 'http://localhost:8899')
    return 'unknown'


def run_crawl4ai_scrape(url: str, format: str = 'markdown') -> tuple[str, int, list]:
    """Sovereign scrape via Crawl4AI. Returns (content, exit_code, command_list).

    The CLI renders clean markdown; html/links are not first-class, so we always
    request markdown (the demo default) and record the requested format label.
    """
    base = ['crwl'] if shutil.which('crwl') else ['uvx', '--from', 'crawl4ai', 'crwl']
    cmd = base + ['crawl', url, '-o', 'markdown']
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=FETCH_TIMEOUT)
    except FileNotFoundError:
        return 'crawl4ai CLI not found', 127, cmd
    except subprocess.TimeoutExpired:
        return f'crawl4ai timed out after {FETCH_TIMEOUT}s', 3, cmd
    if result.returncode != 0 or not result.stdout.strip():
        return (result.stderr or 'crawl4ai returned empty'), (result.returncode or 3), cmd
    return result.stdout, 0, cmd


def run_searxng_search(query: str, limit: int = 10) -> tuple[str, int, list]:
    """Sovereign search via a local SearXNG JSON endpoint. Returns (json, code, cmd)."""
    import urllib.parse
    import urllib.request
    base = os.environ.get('SEARXNG_URL', 'http://localhost:8899').rstrip('/')
    cmd = ['searxng', base, query]
    hits = []
    seen = set()
    try:
        for page in range(1, 4):
            u = base + '/search?' + urllib.parse.urlencode({'q': query, 'format': 'json', 'pageno': page})
            data = json.loads(urllib.request.urlopen(
                urllib.request.Request(u, headers={'User-Agent': 'mycroft-fetch/1.0'}), timeout=30).read())
            results = data.get('results') or []
            if not results:
                break
            for r in results:
                url_ = r.get('url')
                if not url_ or url_ in seen:
                    continue
                seen.add(url_)
                hits.append({'url': url_, 'title': r.get('title', ''),
                             'snippet': (r.get('content') or '')[:300], 'date': r.get('publishedDate')})
                if len(hits) >= limit:
                    return json.dumps(hits, indent=2), 0, cmd
    except Exception as exc:  # noqa: BLE001 - SearXNG unreachable
        return f'SearXNG unreachable at {base}: {exc}', 3, cmd
    return json.dumps(hits, indent=2), 0, cmd


def run_firecrawl_scrape(url: str, format: str = 'markdown') -> tuple[str, int]:
    """Run firecrawl scrape and return content + exit code."""
    cmd = ['firecrawl', 'scrape', url, '--format', format]

    result = subprocess.run(cmd, capture_output=True, text=True)

    if result.returncode != 0:
        return result.stderr or result.stdout, result.returncode

    return result.stdout, 0


def run_firecrawl_search(query: str, limit: int = 10) -> tuple[str, int]:
    """Run firecrawl search and return results + exit code."""
    cmd = ['firecrawl', 'search', query, '--limit', str(limit)]

    result = subprocess.run(cmd, capture_output=True, text=True)

    if result.returncode != 0:
        return result.stderr or result.stdout, result.returncode

    return result.stdout, 0


# --- Output Formatting ---

def output_result(provenance: dict, content: str, json_output: bool = False):
    """Output the fetch result."""
    if json_output:
        print(json.dumps({
            'provenance': provenance,
            'content': content
        }, indent=2))
    else:
        # Human-readable output
        print(f"# Provenance: {provenance['id']}")
        print(f"# URL: {provenance['url']}")
        print(f"# Hash: {provenance['content_hash']}")
        print(f"# Timestamp: {provenance['access_timestamp']}")
        print(f"# ---")
        print(content)


# --- CLI ---

def cmd_scrape(args):
    """Handle scrape command (sovereign default: Crawl4AI; Firecrawl fallback)."""
    content, exit_code, command_list = run_crawl4ai_scrape(args.url, args.format)
    method = 'crawl4ai'
    if exit_code != 0 and shutil.which('firecrawl'):
        print("[crawl4ai failed] falling back to firecrawl", file=sys.stderr)
        content, exit_code = run_firecrawl_scrape(args.url, args.format)
        command_list = ['firecrawl', 'scrape', args.url, '--format', args.format]
        method = 'firecrawl'

    if exit_code != 0:
        print(f"Error: scrape failed\n{content}", file=sys.stderr)
        sys.exit(exit_code)

    # Create and save provenance (acquisition_method = the tool that acquired it)
    provenance = create_provenance_record(args.url, content, args.format,
                                          ' '.join(command_list), method)
    save_provenance(provenance, content)

    # Output
    output_result(provenance, content, args.json)


def cmd_search(args):
    """Handle search command (sovereign default: SearXNG; Firecrawl fallback)."""
    results, exit_code, command_list = run_searxng_search(args.query, args.limit)
    method = 'searxng'
    if exit_code != 0 and shutil.which('firecrawl'):
        print("[searxng failed] falling back to firecrawl", file=sys.stderr)
        results, exit_code = run_firecrawl_search(args.query, args.limit)
        command_list = ['firecrawl', 'search', args.query, '--limit', str(args.limit)]
        method = 'firecrawl'

    if exit_code != 0:
        print(f"Error: search failed\n{results}", file=sys.stderr)
        sys.exit(exit_code)

    # For search, we create a provenance record for the search itself
    # Individual URLs would be scraped separately
    provenance = create_provenance_record(
        url=f"search:{args.query}",
        content=results,
        format='json',
        command=' '.join(command_list),
        acquisition_method=method,
    )
    save_provenance(provenance, results)

    output_result(provenance, results, args.json)


def cmd_provenance_list(args):
    """List provenance records."""
    records = list_provenance()

    if args.json:
        print(json.dumps(records, indent=2))
    else:
        if not records:
            print("No provenance records found.")
            return

        print(f"{'ID':<20} {'Timestamp':<25} {'URL':<50}")
        print("-" * 95)
        for r in records[:20]:  # Show last 20
            url = r['url'][:47] + '...' if len(r['url']) > 50 else r['url']
            print(f"{r['id']:<20} {r['access_timestamp'][:25]:<25} {url:<50}")


def cmd_provenance_show(args):
    """Show a specific provenance record."""
    record = get_provenance(args.id)

    if not record:
        print(f"Provenance record not found: {args.id}", file=sys.stderr)
        sys.exit(1)

    print(json.dumps(record, indent=2))


def main():
    parser = argparse.ArgumentParser(
        description='Provenance-capturing wrapper for firecrawl',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )
    parser.add_argument('--json', action='store_true', help='Output as JSON')

    subparsers = parser.add_subparsers(dest='command', required=True)

    # scrape
    scrape_parser = subparsers.add_parser('scrape', help='Scrape a URL')
    scrape_parser.add_argument('url', help='URL to scrape')
    scrape_parser.add_argument('--format', choices=['markdown', 'html'], default='markdown')
    scrape_parser.set_defaults(func=cmd_scrape)

    # search
    search_parser = subparsers.add_parser('search', help='Search the web')
    search_parser.add_argument('query', help='Search query')
    search_parser.add_argument('--limit', type=int, default=10, help='Max results')
    search_parser.set_defaults(func=cmd_search)

    # provenance
    prov_parser = subparsers.add_parser('provenance', help='Manage provenance records')
    prov_subparsers = prov_parser.add_subparsers(dest='prov_command', required=True)

    prov_list = prov_subparsers.add_parser('list', help='List records')
    prov_list.set_defaults(func=cmd_provenance_list)

    prov_show = prov_subparsers.add_parser('show', help='Show a record')
    prov_show.add_argument('id', help='Provenance ID')
    prov_show.set_defaults(func=cmd_provenance_show)

    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
