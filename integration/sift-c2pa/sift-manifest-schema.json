{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://buriedsignals.com/schemas/sift-manifest-v1.json",
  "title": "SIFT Manifest",
  "description": "Structured output from SIFT fact-checking for C2PA ingredient encoding",
  "type": "object",
  "required": ["schema", "timestamp", "draft", "claims", "sources", "summary"],
  "properties": {
    "schema": {
      "const": "sift-manifest-v1",
      "description": "Schema identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When the fact-check was completed"
    },
    "investigator": {
      "type": "object",
      "description": "Identity of the journalist performing the fact-check",
      "properties": {
        "did": {
          "type": "string",
          "pattern": "^did:",
          "description": "Decentralized identifier"
        },
        "name": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        }
      }
    },
    "draft": {
      "type": "object",
      "description": "The article being fact-checked",
      "required": ["content_hash"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Vault path to the draft"
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:",
          "description": "SHA-256 hash of the draft content"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "claims": {
      "type": "array",
      "description": "Factual claims extracted and verified",
      "items": {
        "type": "object",
        "required": ["id", "text", "verdict"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^claim-",
            "description": "Unique claim identifier"
          },
          "text": {
            "type": "string",
            "description": "The factual claim as stated"
          },
          "verdict": {
            "type": "string",
            "enum": ["verified", "partially_verified", "unverified", "contradicted", "mischaracterized"],
            "description": "SIFT verdict"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^prov-"
            },
            "description": "Provenance IDs of sources used to verify this claim"
          },
          "notes": {
            "type": "string",
            "description": "Additional context or explanation"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence level (optional)"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "description": "All sources consulted during fact-checking",
      "items": {
        "type": "object",
        "required": ["id", "content_hash", "access_timestamp"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^prov-",
            "description": "Provenance ID from mycroft-fetch"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Source URL"
          },
          "vault_path": {
            "type": "string",
            "description": "Path to vault note (for local sources)"
          },
          "content_hash": {
            "type": "string",
            "pattern": "^sha256:",
            "description": "SHA-256 hash of source content at access time"
          },
          "access_timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "When the source was accessed"
          },
          "access_type": {
            "type": "string",
            "enum": ["full", "excerpt", "abstract", "archive", "inaccessible"],
            "description": "How much of the source was accessible"
          },
          "sift_step": {
            "type": "string",
            "enum": ["stop", "investigate_source", "find_better_coverage", "trace_to_original"],
            "description": "Which SIFT step this source was used in"
          },
          "is_primary": {
            "type": "boolean",
            "description": "Whether this is a primary source"
          },
          "title": {
            "type": "string",
            "description": "Human-readable source title"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Verdict counts",
      "properties": {
        "verified": { "type": "integer", "minimum": 0 },
        "partially_verified": { "type": "integer", "minimum": 0 },
        "unverified": { "type": "integer", "minimum": 0 },
        "contradicted": { "type": "integer", "minimum": 0 },
        "mischaracterized": { "type": "integer", "minimum": 0 },
        "total_claims": { "type": "integer", "minimum": 0 },
        "total_sources": { "type": "integer", "minimum": 0 }
      }
    },
    "methodology": {
      "type": "object",
      "description": "Methodology metadata",
      "properties": {
        "name": { "const": "SIFT" },
        "version": { "type": "string" },
        "vault_searched": { "type": "boolean" },
        "web_searched": { "type": "boolean" }
      }
    }
  }
}
